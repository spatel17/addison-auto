---
interface Props {
  title: string;
}

const { title } = Astro.props;
import '../styles/global.css';
import Footer from './Footer.astro'; 
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Professional auto repair in Addison, IL. Offering transmission repair, brake services, engine diagnostics, and scheduled maintenance for all vehicle makes." />
    <title>{title}</title>
    <link rel="canonical" href="https://addisonautorepair.com/" />
  </head>
  <body>
    <!-- Premium Minimal Navbar -->
    <header class="container navbar">
      <a href="/" class="logo">ADDISON AUTO REPAIR</a>
      <nav>
        <a href="#services">Services</a>
        <a href="#about">About</a>
      </nav>
    </header>

    <slot />

    <Footer />

    <style>
      .navbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 2rem;
        padding-bottom: 2rem;
      }
      .logo {
        font-weight: 700;
        letter-spacing: -0.05em;
        font-size: 1.25rem;
      }
      nav {
        display: flex;
        align-items: center;
        gap: 2.5rem;
      }
      nav a {
        color: var(--text-secondary);
        font-size: 0.95rem;
        transition: color 0.2s ease;
      }
      nav a:hover {
        color: var(--text-primary);
      }
    </style>
  </body>
</html>